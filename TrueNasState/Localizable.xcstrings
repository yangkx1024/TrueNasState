    "Generate a user-linked API key in TrueNAS → Settings → My API Keys. The key is stored in your macOS Keychain." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erzeugen Sie einen benutzergebundenen API-Schlüssel in TrueNAS → Settings → My API Keys. Der Schlüssel wird in Ihrem macOS-Schlüsselbund gespeichert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Genera una clave API vinculada al usuario en TrueNAS → Settings → My API Keys. La clave se almacena en tu llavero de macOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Générez une clé API liée à un utilisateur dans TrueNAS → Settings → My API Keys. La clé est stockée dans votre trousseau macOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TrueNAS → Settings → My API Keys でユーザー連携の API キーを生成してください。キーは macOS のキーチェーンに保存されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 TrueNAS → Settings → My API Keys 中生成与用户关联的 API 密钥。该密钥存储在你的 macOS 钥匙串中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
